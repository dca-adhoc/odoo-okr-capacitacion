<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- vista de lista de OKRs -->
    <record id="view_okr_management_tree" model="ir.ui.view">
        <field name="name">okr.management.tree</field>
        <field name="model">okr.management</field>
        <field name="arch" type="xml">
            <list string="OKRs">
                <field name="name"/>
                <field name="level"/>
                <field name="period"/>
            </list>
        </field>
    </record>
    <!-- vista de formulario de OKRs -->
    <record id="view_okr_management_form" model="ir.ui.view">
        <field name="name">okr.management.form</field>
        <field name="model">okr.management</field>
        <field name="arch" type="xml">
            <form string="OKR">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ej: Plan Estratégico 2026"/>
                        </h1>
                    </div>
                    <group string="Configuración">
                            <field name="level"/>
                            <field name="parent_id" placeholder="Seleccioná si depende de otro OKR"/>
                            <field name="responsible_id" widget="many2one_avatar_user"/>
                        </group>
                        <group string="Ciclo y Período">
                            <field name="year" widget="integer" options="{'format': false, 'type': 'number'}"/>
                            <field name="period_type"/>
                            <field name="period"/>

                            <label for="date_start" string="Duración"/>
                            <div class="o_row">
                                <field name="date_start" readonly="1" force_save="1"/>
                                <span> a </span>
                                <field name="date_end" readonly="1" force_save="1"/>
                            </div>
                        </group>
                    <notebook>
                        <page string="Objetivos" name="objectives">
                            <field name="objective_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="type"/>
                                    <field name="responsible_id"/>
                                    <field name="progress" widget="progressbar"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!-- acción para la gestión de OKRs -->
    <record id="action_okr_management" model="ir.actions.act_window">
        <field name="name">Gestión de OKRs</field>
        <field name="res_model">okr.management</field>
        <field name="view_mode">list,form</field> </record>

    <!-- Menús para acceder a la gestión de OKRs -->
    <menuitem id="menu_okr_root" name="OKRs" web_icon="okr_management,static/description/icon.png" sequence="10"/>
    <menuitem id="menu_okr_main" name="Todos los OKRs" parent="menu_okr_root" action="action_okr_management" sequence="10"/>

    <record id="action_okr_mine" model="ir.actions.act_window">
        <field name="name">Mis OKRs</field>
        <field name="res_model">okr.management</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('responsible_id', '=', uid)]</field>
    </record>
    <menuitem id="menu_okr_mine" name="Mis OKRs" parent="menu_okr_root" action="action_okr_mine" sequence="20"/>
</odoo>
